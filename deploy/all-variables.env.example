# Complete environment variable checklist for ott-backend deployment
#
# IMPORTANT:
# - Section 1 goes to GitHub Actions Variables.
# - Section 2 stays on the EC2 server at /opt/ott/.env.
# - Section 3 stays on the EC2 server at /opt/ott/.env.images.
# - Do NOT put database passwords, JWT secrets, mail passwords, S3 keys, or AI keys in GitHub Variables for the current workflow.

################################################################################
# 1) GITHUB ACTIONS VARIABLES
# Location:
# GitHub repo -> Settings -> Secrets and variables -> Actions -> Variables
################################################################################

AWS_ACCOUNT_ID=158988874695
AWS_REGION=ap-southeast-1
AWS_DEPLOY_ROLE_ARN=arn:aws:iam::158988874695:role/ott-github-actions-deploy-role
EC2_TAG_NAME=ott-backend-prod
IMAGE_PLATFORM=linux/amd64

################################################################################
# 2) EC2 RUNTIME ENV
# Location on EC2:
# /opt/ott/.env
#
# Copy from deploy/env.example, then replace values on the EC2 server:
# cp deploy/env.example /opt/ott/.env
################################################################################

TZ=Asia/Ho_Chi_Minh

# Frontend / CORS
FRONTEND_URL=https://app.example.com
FRONTEND_URL_ALT=http://localhost:3000
FRONTEND_URL_DEPLOYED=https://*.vercel.app
CHAT_ALLOWED_ORIGINS=https://app.example.com,https://*.vercel.app,http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOWED_ORIGINS=

# Auth / Gateway JWT
JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=86400
INTERNAL_API_KEY=replace-with-long-random-internal-key

# Auth service PostgreSQL
AUTH_DB_URL=jdbc:postgresql://example-auth-db:5432/auth_db
AUTH_DB_USERNAME=replace-me
AUTH_DB_PASSWORD=replace-me

# User service PostgreSQL
USER_DB_URL=jdbc:postgresql://example-user-db:5432/user_db
USER_DB_USERNAME=replace-me
USER_DB_PASSWORD=replace-me

# Notification service PostgreSQL
NOTIF_DB_URL=jdbc:postgresql://example-notification-db:5432/notification_db
NOTIF_DB_USERNAME=replace-me
NOTIF_DB_PASSWORD=replace-me

# Media/social service PostgreSQL
SOCIAL_DB_URL=jdbc:postgresql://example-social-db:5432/social_db
SOCIAL_DB_USERNAME=replace-me
SOCIAL_DB_PASSWORD=replace-me

# Chat service MongoDB
MONGO_URI=mongodb+srv://replace-me
CHAT_SERVICE_MONGO_MAX_POOL_SIZE=30
CHAT_SERVICE_MONGO_MIN_POOL_SIZE=2
CHAT_WORKER_MONGO_MAX_POOL_SIZE=5
CHAT_WORKER_MONGO_MIN_POOL_SIZE=1
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_CONNECT_TIMEOUT_MS=10000
MONGO_SOCKET_TIMEOUT_MS=45000
MONGO_MAX_IDLE_TIME_MS=30000

# Redis and RabbitMQ containers on EC2
REDIS_PASSWORD=replace-me
REDIS_DB=0
RABBITMQ_USERNAME=admin
RABBITMQ_PASSWORD=replace-me

# Email for notification-service
MAIL_USERNAME=replace-me
MAIL_PASSWORD=replace-me
MAIL_FROM=noreply@example.com
MAIL_FROM_NAME=Riff

# Google OAuth for auth-service
GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me

# S3 used by user-service and chat-service
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
AWS_S3_BUCKET_NAME=replace-me
AWS_DEFAULT_AVATAR_URL=https://example.com/default-avatar.png
AWS_DEFAULT_COVER_PHOTO_URL=https://example.com/default-cover.png

# S3 used by media-service
AWS_SOCIAL_ACCESS_KEY_ID=replace-me
AWS_SOCIAL_SECRET_ACCESS_KEY=replace-me
AWS_SOCIAL_REGION=ap-southeast-1
AWS_SOCIAL_S3_BUCKET_NAME=replace-me
AWS_SOCIAL_S3_BASE_URL=https://replace-me.s3.ap-southeast-1.amazonaws.com
AWS_SOCIAL_S3_USE_LOCAL=false

# Local analytic-postgres container and analytic-service
ANALYTIC_DB_NAME=admin_analytic_db
ANALYTIC_DB_USERNAME=postgres
ANALYTIC_DB_PASSWORD=replace-me
ANALYTIC_ALLOWED_ORIGINS=https://riff-iuh.vercel.app

# Moderation service
MODERATION_DB_URL=jdbc:postgresql://example-moderation-db:5432/moderation_db
MODERATION_DB_USERNAME=replace-me
MODERATION_DB_PASSWORD=replace-me
MODERATION_REVIEW_REQUEST_DLQ=moderation.review.requests.dlq

# Media relationship socket
RELATIONSHIP_SOCKET_HOST=0.0.0.0
RELATIONSHIP_SOCKET_PORT=8091
RELATIONSHIP_SOCKET_ORIGIN=*

# AI / Groq used by chat-service
GROQ_API_KEY=replace-me
GROQ_TEXT_MODEL=llama-3.1-8b-instant
GROQ_FALLBACK_MODELS=
GROQ_STT_MODEL=whisper-large-v3
GROQ_STT_FALLBACK_MODELS=whisper-large-v3-turbo,whisper-large-v3
GROQ_STT_LANGUAGE=vi
AI_TIMEOUT_MS=18000
AI_STT_TIMEOUT_MS=30000
AI_MAX_AUDIO_BYTES=26214400
AI_DISABLE_STRICT_SCHEMA=
FFMPEG_PATH=

# LiveKit used by chat-service
LIVEKIT_API_KEY=replace-me
LIVEKIT_API_SECRET=replace-me
LIVEKIT_URL=wss://replace-me.livekit.cloud

# Optional moderation / Redis tuning for chat-service
REKOGNITION_MIN_CONFIDENCE=80
MODERATION_FAIL_CLOSED=false
PRESENCE_TTL_SECONDS=90
PRESENCE_RECONCILE_INTERVAL_MS=60000
USER_CACHE_TTL=3600
USER_STATUS_LOOKUP_TIMEOUT_MS=2500
MODERATION_RABBITMQ_EXCHANGE=
MODERATION_REVIEW_REQUEST_ROUTING_KEY=
ANALYTICS_MESSAGE_SENT_QUEUE=analytics.message.sent.queue
CHAT_ASYNC_SEND_ENABLED=true
CHAT_ASYNC_SEND_RESPONSE_STATUS=202
CHAT_MESSAGE_COMMAND_QUEUE=chat.message.command.queue
CHAT_MESSAGE_COMMAND_DLQ=chat.message.command.dlq
CHAT_MESSAGE_COMMAND_PREFETCH=50
CHAT_MESSAGE_COMMAND_CONSUMER_ENABLED=false
CHAT_MESSAGE_COMMAND_CONFIRM=false
CHAT_MESSAGE_COMMAND_WAIT_DRAIN=false
CHAT_MESSAGE_COMMAND_PERSISTENT=true
CHAT_QUEUED_SEND_ACCOUNT_STATUS_CHECK_ENABLED=false
CHAT_RECEIPT_QUEUE_ENABLED=false
CHAT_REALTIME_EVENT_PREFETCH=5
CHAT_DELIVERY_PARTICIPANTS_CACHE_TTL_SECONDS=60
CHAT_CONVERSATION_LIST_CACHE_ENABLED=true
CHAT_CONVERSATION_LIST_CACHE_TTL_SECONDS=10
CHAT_CONVERSATION_LIST_STALE_TTL_SECONDS=600
CHAT_CONVERSATION_LIST_DB_TIMEOUT_MS=2500
CHAT_CONVERSATION_LIST_ENSURE_SELF_SYNC=false
CHAT_SEND_REDIS_CACHE_ENABLED=true
CHAT_SEND_REDIS_CACHE_TTL_SECONDS=60
CHAT_MESSAGE_CACHE_STRICT_DB_CHECK=false
CHAT_MESSAGE_CACHE_LIVE_REACTIONS=false
CHAT_MESSAGE_CACHE_HYDRATE_SENDERS=false
CHAT_MESSAGE_CACHE_HYDRATE_REPLIES=false

# EC2 Docker disk/log guardrails
DOCKER_LOG_MAX_SIZE=20m
DOCKER_LOG_MAX_FILE=3
DOCKER_IMAGE_PRUNE_UNTIL=72h
DOCKER_BUILDER_PRUNE_UNTIL=72h
DOCKER_LOG_TRUNCATE_OVER=200M

################################################################################
# 3) EC2 IMAGE ENV
# Location on EC2:
# /opt/ott/.env.images
#
# Copy from deploy/env.images.example, then replace AWS account id:
# cp deploy/env.images.example /opt/ott/.env.images
################################################################################

API_GATEWAY_IMAGE=158988874695.dkr.ecr.ap-southeast-1.amazonaws.com/ott-api-gateway:latest
AUTH_SERVICE_IMAGE=158988874695.dkr.ecr.ap-southeast-1.amazonaws.com/ott-auth-service:latest
USER_SERVICE_IMAGE=158988874695.dkr.ecr.ap-southeast-1.amazonaws.com/ott-user-service:latest
NOTIFICATION_SERVICE_IMAGE=158988874695.dkr.ecr.ap-southeast-1.amazonaws.com/ott-notification-service:latest
MEDIA_SERVICE_IMAGE=158988874695.dkr.ecr.ap-southeast-1.amazonaws.com/ott-media-service:latest
CHAT_SERVICE_IMAGE=158988874695.dkr.ecr.ap-southeast-1.amazonaws.com/ott-chat-service:latest
ANALYTIC_SERVICE_IMAGE=158988874695.dkr.ecr.ap-southeast-1.amazonaws.com/ott-analytic-service:latest
MODERATION_SERVICE_IMAGE=158988874695.dkr.ecr.ap-southeast-1.amazonaws.com/ott-moderation-service:latest

################################################################################
# 4) FRONTEND ENV REMINDER
# These do NOT belong to ott-backend GitHub Actions.
# Put them in the corresponding frontend project deployment settings.
################################################################################

VITE_API_URL=http://13.215.227.27/riff/api
VITE_FRONTEND_URL=https://riff-iuh.vercel.app
VITE_RELATIONSHIP_SOCKET_URL=https://api.example.com
VITE_MEDIA_SOCKET_URL=https://api.example.com
VITE_LIVEKIT_URL=wss://replace-me.livekit.cloud

EXPO_PUBLIC_API_URL=https://api.example.com/riff/api
EXPO_PUBLIC_WEB_URL=https://app.example.com
